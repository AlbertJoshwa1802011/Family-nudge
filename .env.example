# ---------- Supabase ----------
# Create a project at https://supabase.com (free tier) then copy values from
# Project Settings -> API and Project Settings -> Database.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key      # server-only; never ship to clients
SUPABASE_DB_URL=postgresql://postgres:PASSWORD@db.YOUR-PROJECT-REF.supabase.co:5432/postgres

# ---------- Expo / mobile ----------
# Duplicated for the mobile bundle; Expo only exposes EXPO_PUBLIC_ vars.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ---------- Meta WhatsApp Cloud API ----------
# Create an app at https://developers.facebook.com -> WhatsApp (free 1000 conversations/month).
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=choose-any-random-string
WHATSAPP_APP_SECRET=

# ---------- Google Cloud Text-to-Speech ----------
# Free tier: 1M chars/month Standard, 1M chars/month WaveNet.
# Create a service account with Cloud TTS API enabled and paste the JSON below (base64).
GOOGLE_TTS_CREDENTIALS_B64=

# ---------- App ----------
APP_URL=http://localhost:3000
APP_ENV=development
