{
  "name": "family-nudge",
  "version": "0.1.0",
  "private": true,
  "description": "Smart family management platform — reminders, document vault, insurance/warranty tracking",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:generate": "pnpm --filter @family-nudge/api exec prisma generate",
    "db:migrate": "pnpm --filter @family-nudge/api exec prisma migrate dev",
    "db:push": "pnpm --filter @family-nudge/api exec prisma db push",
    "db:studio": "pnpm --filter @family-nudge/api exec prisma studio"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma",
      "sharp"
    ]
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
